<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="290dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#EE0F172A"
    app:cardCornerRadius="14dp"
    app:cardElevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Row 1: status text + close button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/transcriptText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tap below, then play the message"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.35"
                android:layout_marginEnd="6dp" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Dismiss"
                android:tint="#888888" />
        </LinearLayout>

        <!-- Row 2: action buttons (shown in idle state) -->
        <LinearLayout
            android:id="@+id/rowActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="start">

            <!-- "Transcribe" button — visible when idle -->
            <Button
                android:id="@+id/btnTranscribe"
                style="@android:style/Widget.Material.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🎙 Transcribe"
                android:textColor="#42A5F5"
                android:textSize="12sp"
                android:paddingStart="0dp"
                android:paddingEnd="12dp" />

            <!-- "Stop" button — visible while recording -->
            <Button
                android:id="@+id/btnStop"
                style="@android:style/Widget.Material.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="⏹ Stop"
                android:textColor="#EF5350"
                android:textSize="12sp"
                android:visibility="gone"
                android:paddingStart="0dp"
                android:paddingEnd="12dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
